#!/usr/bin/env bash
# Local CI: full quick health check before every push.
# Bypass with `git push --no-verify` if you really need to.
# Activate with: just setup-hooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if ! command -v just >/dev/null 2>&1; then
    echo "pre-push: 'just' not installed; skipping checks" >&2
    exit 0
fi

exec just health-check-quick
